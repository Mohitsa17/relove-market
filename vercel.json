{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4",
            "config": {
                "excludeFiles": [
                    "node_modules/**",
                    "public/**",
                    "resources/**",
                    "storage/framework/cache/**",
                    "storage/framework/sessions/**",
                    "storage/framework/views/**",
                    "tests/**",
                    "ml_service/**"
                ]
            }
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public/build"
            }
        }
    ],
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
