{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4",
            "config": {
                "excludeFiles": [
                    "node_modules/**",
                    "resources/css/**",
                    "resources/js/**",
                    "storage/framework/cache/**",
                    "storage/framework/sessions/**",
                    "storage/framework/views/**",
                    "tests/**",
                    "ml_service/**"
                ]
            }
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "public"
            }
        }
    ],
    "routes": [
        {
            "src": "/(index\\.php)?",
            "dest": "/api/index.php"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
