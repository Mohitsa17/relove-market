{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4",
            "config": {
                "excludeFiles": [
                    "node_modules/**",
                    "resources/css/**",
                    "resources/js/**",
                    "storage/framework/cache/**",
                    "storage/framework/sessions/**",
                    "storage/framework/views/**",
                    "tests/**",
                    "ml_service/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/|/index\\.php",
            "dest": "/api/index.php"
        },
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/image/(.*)",
            "dest": "/public/image/$1"
        },
        {
            "src": "/storage/(.*)",
            "dest": "/public/storage/$1"
        },
        {
            "src": "/(manifest\\.json|sw\\.js|offline\\.html|favicon\\.ico|robots\\.txt|.*\\.png|.*\\.ico)",
            "dest": "/public/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}
